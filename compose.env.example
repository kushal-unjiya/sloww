# Docker Compose environment (repo root)
#
# Compose uses this file for variable interpolation (POSTGRES_*, GCS_*, Clerk, etc.).
# It is NOT loaded by the services when you run them on the host with ./run-dev.sh.
#
# Usage:
#   cp compose.env.example compose.env
#   docker compose --env-file compose.env up --build
#

# ── PostgreSQL (Compose) ────────────────────────────────────────────────────
POSTGRES_DB=sloww-ai
POSTGRES_USER=slowwadmin
POSTGRES_PASSWORD=POSTgres

# ── Service wiring (Compose network) ───────────────────────────────────────
INFERENCE_URL=http://inference:8001
APP_URL=http://app:8000

# ── Qdrant (Compose) ───────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── Google Cloud Storage (required) ────────────────────────────────────────
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Data-loader worker defaults (Compose) ──────────────────────────────────
INGEST_MODE=poll
WORKER_ID=data-loader-1

# ── Internal auth (backend → inference) ────────────────────────────────────
INTERNAL_TOKEN=changeme

# ── Clerk ──────────────────────────────────────────────────────────────────
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_SECRET_KEY=

# ── UI build args (Compose) ────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=

