# ── PostgreSQL ─────────────────────────────────────────────────────────────
# One logical database name + user + password. The Docker `postgres` service reads
# POSTGRES_* to create that database on first start. Use the SAME trio in DATABASE_URL.
#
# To match what you used on local Postgres before: copy your old database name, role,
# and password into POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD (and into DATABASE_URL).
# Special characters in the password must be URL-encoded in DATABASE_URL (e.g. @ → %40).

POSTGRES_DB=sloww-ai
POSTGRES_USER=slowwadmin
POSTGRES_PASSWORD=POSTgres

# ── Postgres in Docker, published on host port 5432 ──────────────────────────
#
# POSTGRES_* must match the user, password, and database name you use in DATABASE_URL.
# docker-compose overrides DATABASE_URL inside backend/inference/data-loader to use host
# `postgres` (Docker network); your .env keeps `localhost` for tools on your Mac.
#
DATABASE_URL=postgresql+psycopg://slowwadmin:POSTgres@localhost:5432/sloww-ai
# Inference may use postgresql+asyncpg://... in the same file; the backend and Alembic rewrite
# that to postgresql+psycopg:// automatically (sync SQLAlchemy + psycopg3).
#
# DBeaver: localhost, port 5432, same DB/user/password as above.
# Alembic from `backend/` (postgres container running): uses the same DATABASE_URL as in this file.
#
# Cloud: set DATABASE_URL to the provider URL; drop the compose-only postgres override
# or set POSTGRES_* to match the provider if you still build URLs from them.

# Alembic + SQL migrations target this schema (underscore; not the DB name).
DB_SCHEMA=sloww_ai

# ── Services (docker-compose defaults) ─────────────────────────────────────
INFERENCE_URL=http://inference:8001
APP_URL=http://app:8000

# Optional: backend startup probes (best-effort). Set for your deployment.
# Examples:
# BACKEND_INFERENCE_URL=http://127.0.0.1:8001
# BACKEND_UI_URL=http://127.0.0.1:3000
# BACKEND_DATA_LOADER_URL=http://127.0.0.1:8003

# Qdrant (local)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── Google Cloud Storage (required) ─────────────────────────────────────────
# Create a bucket in GCP Console, then set:
GCS_BUCKET_NAME=your-bucket-name

# Optional if your default gcloud project differs from the bucket’s project:
# GCS_PROJECT_ID=your-gcp-project-id
#
# Credentials (pick one):
#
# 1) Local / laptop — service account JSON key:
#    IAM & Admin → Service Accounts → your SA → Keys → Add JSON key.
#    Never commit the file. Point env at its path:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json
#
# 2) Local — user ADC (limited; V4 signed URLs usually need a service account key):
#    gcloud auth application-default login
#
# 3) Cloud Run / GCE — attach a service account with roles such as
#    roles/storage.objectAdmin (or tighter objectCreator + objectViewer + deleter).
#    Do not set GOOGLE_APPLICATION_CREDENTIALS; metadata server provides identity.
#
# Docker Compose: mount the key and set the in-container path via docker-compose.override.yml
# (see SETUP.md).

# ── Embeddings (data-loader + inference — same model and dimension) ─────────
# NVIDIA NIM example (2048-dim; use input_type passage at ingest, query at search — wired in code).
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
EMBEDDING_VECTOR_SIZE=2048
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HF_API_KEY=

# ── Data-loader run mode ────────────────────────────────────────────────────
# poll = long-running worker (default local). push = HTTP server for Cloud Run + Pub/Sub push.
INGEST_MODE=poll

# ── Pub/Sub (optional; GCP) After upload, backend can publish a message so Cloud Run ingests. ──
PUBSUB_ENABLED=false
PUBSUB_PROJECT_ID=
# Topic id only, or full resource: projects/PROJECT_ID/topics/TOPIC_NAME
PUBSUB_INGESTION_TOPIC=ingestion-jobs

# Worker identity (use a unique value per Cloud Run replica if you scale horizontally)
WORKER_ID=data-loader-1

# Internal auth between app <-> inference
INTERNAL_TOKEN=changeme

# ── Clerk (JWT verification + optional user profile fetch) ───────────────────
# Replace the hostname with YOUR real Clerk Frontend API host (not the literal text
# "YOUR_INSTANCE"). In Clerk Dashboard: select your app → Configure → API Keys →
# copy the JWKS URL and issuer for session JWTs.
#
# Example shape (use your own subdomain):
# CLERK_JWKS_URL=https://happy-foo-12.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWT_ISSUER=https://happy-foo-12.clerk.accounts.dev
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
# Optional: for /me when the JWT has no email claim (recommended for dev/prod).
CLERK_SECRET_KEY=sk_test_...

# ── UI (Vite; only vars prefixed VITE_ are exposed to the browser) ──────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Browser-reachable API base (host machine when using Docker for UI + API).
VITE_APP_URL=http://127.0.0.1:8000

# ── Supabase (optional; replace local DATABASE_URL when using hosted Postgres) ─
# DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require
# Same DB + password for inference/asyncpg and data-loader/psycopg — only change the driver prefix.

# ── Vercel (frontend build-time; copy into Vercel project env) ───────────────
# VITE_APP_URL=https://your-backend-xxxxx-xx.a.run.app
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
