# Backend service env (host-run: cd backend && ./run-dev.sh)
#
# Copy:
#   cp .env.example .env
#

DATABASE_URL=postgresql+psycopg://slowwadmin:POSTgres@localhost:5432/sloww-ai
DB_SCHEMA=sloww_ai

# Service wiring (host-run)
INFERENCE_URL=http://127.0.0.1:8001
INTERNAL_TOKEN=changeme

# Qdrant (host-run)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# Google Cloud Storage (required)
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=

# Local auth (service account JSON key)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# Clerk
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_SECRET_KEY=

# Log level
LOG_LEVEL=INFO

