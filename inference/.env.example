# Database (read-only consumer — backend owns migrations)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sloww
DB_SCHEMA=sloww_ai

# Vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Embedding — MUST match data-loader's EMBEDDING_MODEL exactly
EMBEDDING_MODEL=BAAI/bge-m3
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HF_API_KEY=

# LLM fallback chain (inference)
# Gemini: use either name — Google docs often use GOOGLE_API_KEY; both are accepted.
GROQ_API_KEY=
GOOGLE_API_KEY=
# GOOGLE_AI_API_KEY=
LLM_PRIMARY_MODEL=groq:llama-3.1-8b-instant
LLM_OPENROUTER_MODEL=openrouter:meta-llama/llama-3.1-8b-instruct
LLM_GOOGLE_MODEL=google:gemma-4-26b-a4b-it
# Alt Gemma 4 on Gemini API: google:gemma-4-31b-it
# Dev: use only Google — set LLM_PROVIDER_CHAIN=google
LLM_PROVIDER_CHAIN=groq,openrouter,google
# Optional: fast routing (intent / HyDE / coverage / planner). Same keys as LLM_PROVIDER_CHAIN.
# Example: LLM_ROUTER_CHAIN=groq with LLM_PROVIDER_CHAIN=google uses Groq for routing, Google for answers.
LLM_ROUTER_CHAIN=groq
# If router uses google, set a fast model (e.g. google:gemini-2.0-flash); optional.
LLM_ROUTER_GOOGLE_MODEL=

# Cross-encoder (loaded locally at startup)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Graph tuning
LOOP_MAX=3
COVERAGE_THRESHOLD=0.65
# If true, obvious chitchat skips LLM intent (faster).
CHITCHAT_INTENT_HEURISTIC=true
# Expensive: extra full LLM calls when citation format fails. Default 0 = one call + local line repair.
CITATION_ASSERT_RETRIES=0
# Skip an LLM/embedding provider for this many seconds after a failed request.
PROVIDER_FAILURE_COOLDOWN_SECONDS=60

# Observability (logs-only correlation)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Service identity
SERVICE_NAME=inference
ENVIRONMENT=development
LOG_LEVEL=INFO

# Service-to-service auth
INTERNAL_TOKEN=

