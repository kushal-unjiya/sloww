# Data-loader worker env (host-run: cd data-loader && ./run-dev.sh)
#
# Copy:
#   cp .env.example .env
#

DATABASE_URL=postgresql+psycopg://slowwadmin:POSTgres@localhost:5432/sloww-ai
DB_SCHEMA=sloww_ai

# Worker identity / mode
INGEST_MODE=poll
WORKER_ID=data-loader-1

# Qdrant (host-run)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# Google Cloud Storage (required)
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# Embeddings (must match inference)
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
EMBEDDING_VECTOR_SIZE=2048
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HF_API_KEY=

LOG_LEVEL=INFO

